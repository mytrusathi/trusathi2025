rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['group-admin', 'super-admin'];
    }

    function isSuperAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isOwner(userId)
                    && (isSuperAdmin() || (
                      request.resource.data.role == resource.data.role &&
                      request.resource.data.isApproved == resource.data.isApproved
                    ));
      allow delete: if isSuperAdmin();
    }

    match /profiles/{profileId} {
      allow get: if true;
      allow list: if resource.data.isPublic == true 
                  || (request.auth != null && resource.data.createdBy == request.auth.uid)
                  || isAdmin();
      
      allow create: if isSignedIn() 
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.isPublic is bool;
                    
      allow update: if (isSignedIn() && resource.data.createdBy == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /favorites/{favId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.userId == request.auth.uid || 
        favId.split('_')[0] == request.auth.uid
      );
      allow write: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        favId.split('_')[0] == request.auth.uid
      );
    }

    match /interests/{interestId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.receiverId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      ) && (
        // Prevent sender from accepting their own interest
        (request.resource.data.status != resource.data.status) ? 
          (resource.data.receiverId == request.auth.uid) : true
      );
      
      allow delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        isAdmin()
      );
    }

    match /conversations/{conversationId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid in request.resource.data.participants ||
        isAdmin()
      );

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid])
          || isAdmin()
        );
        
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid])
        ) && (
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() <= 2000
        );

        allow update, delete: if isAdmin();
      }
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }

    match /partner_preferences/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
