rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['group-admin', 'super-admin'];
    }

    function isSuperAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
    }

    // --- Collections ---

    match /users/{userId} {
      // 🔥 SECURITY FIX: Restrict reading whole user docs to Owner and Admins only.
      allow read: if isOwner(userId) || isAdmin(); 
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || (
                      isOwner(userId) &&
                      request.resource.data.role == resource.data.role &&
                      request.resource.data.isApproved == resource.data.isApproved
                    );
      allow delete: if isSuperAdmin();
    }

    match /profiles/{profileId} {
      allow get: if true;
      allow list: if resource.data.isPublic == true 
                  || (request.auth != null && resource.data.createdBy == request.auth.uid)
                  || isAdmin();
      
      allow create: if isSignedIn() 
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.isPublic is bool;
                    
      allow update: if (isSignedIn() && resource.data.createdBy == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // 🔥 NEW: Private profile data collection (Contact Details)
    match /profile_private/{profileId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.createdBy) ||
        isAdmin() ||
        // Allow if an "Accepted" interest exists from the reader to this profile
        exists(/databases/$(database)/documents/interests/$(request.auth.uid + "_" + profileId)) &&
        get(/databases/$(database)/documents/interests/$(request.auth.uid + "_" + profileId)).data.status == 'accepted' ||
        // OR if the profile has "revealContactOnInterest" set to true and an interest is sent (even if pending)
        (
          get(/databases/$(database)/documents/profiles/$(profileId)).data.revealContactOnInterest == true &&
          exists(/databases/$(database)/documents/interests/$(request.auth.uid + "_" + profileId))
        )
      );
      
      allow write: if isSignedIn() && (
        isOwner(request.resource.data.createdBy) || isAdmin()
      );
    }

    match /favorites/{favId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.userId == request.auth.uid || 
        favId.split('_')[0] == request.auth.uid
      );
      allow write: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        favId.split('_')[0] == request.auth.uid
      );
    }

    match /interests/{interestId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.receiverId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      ) && (
        (request.resource.data.status != resource.data.status) ? 
          (resource.data.receiverId == request.auth.uid) : true
      );
      
      allow delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        isAdmin()
      );
    }

    match /conversations/{conversationId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid in request.resource.data.participants ||
        isAdmin()
      );

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid])
          || isAdmin()
        );
        
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid])
        ) && (
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() <= 2000
        );

        allow update, delete: if isAdmin();
      }
    }

    match /screening_requests/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && (
        !exists(/databases/$(database)/documents/screening_requests/$(userId))
      );
      allow update: if isAdmin() || (isOwner(userId) && resource.data.status != 'pending');
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      // 🔥 SECURITY FIX: Only allow creation if senderId matchesauthenticated user
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid; 
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }

    match /partner_preferences/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
