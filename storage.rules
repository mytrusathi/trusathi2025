rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Global helper
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Profile Images & Selfies Directory
    match /{dir}/{userId}/{allPaths=**} {
      // dir can be 'profiles' or 'selfies'
      
      // Anyone can load the image (if they have the URL)
      allow read: if true;
      
      // Only the authenticated user can upload to their own folder
      allow write: if isOwner(userId)
                   && request.resource.size < 2 * 1024 * 1024 // 2MB Limit
                   && request.resource.contentType.matches('image/.*')
                   && (dir == 'profiles' || dir == 'selfies' || dir == 'verification_docs');
    }

    // Specific protection for verification docs (Private)
    match /verification_docs/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || 
                  (isSignedIn() && 
                   exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
                   get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['group-admin', 'super-admin']);
    }
  }
}
